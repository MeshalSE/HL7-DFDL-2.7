            <xsd:element maxOccurs="1" minOccurs="0" name="lname" type="xsd:string"/>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:element dfdl:initiator="ZVX" dfdl:ref="ibmhl7:HL7SegmentTerminator" name="ZVX" type="ZVX.CONTENT"/>
